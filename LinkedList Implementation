    public int middle() {
        if (head == null)
            return -1;

        Node slow = head;
        Node fast = head;

        while (fast != null && fast.next != null) {
            slow = slow.next;
            fast = fast.next.next;
        }

        return slow.data;
    }

    public int nthFromEnd(int n) {
        if (n <= 0 || n > size)
            return -1;

        Node first = head;
        Node second = head;

        for (int i = 0; i < n; i++)
            first = first.next;

        while (first != null) {
            first = first.next;
            second = second.next;
        }

        return second.data;
    }

    public boolean search(int value) {
        Node temp = head;

        while (temp != null) {
            if (temp.data == value)
                return true;

            temp = temp.next;
        }

        return false;
    }

    public int countOccurrences(int value) {
        int count = 0;
        Node temp = head;

        while (temp != null) {
            if (temp.data == value)
                count++;

            temp = temp.next;
        }

        return count;
    }

    public boolean detectLoop() {
        Node slow = head;
        Node fast = head;

        while (fast != null && fast.next != null) {
            slow = slow.next;
            fast = fast.next.next;

            if (slow == fast)
                return true;
        }

        return false;
    }

    public void createLoop() {
        if (head != null)
            tail.next = head;
    }

    public void removeDuplicates() {
        Node current = head;

        while (current != null) {
            Node temp = current;

            while (temp.next != null) {
                if (temp.next.data == current.data) {
                    if (temp.next == tail)
                        tail = temp;

                    temp.next = temp.next.next;
                    size--;
                } else {
                    temp = temp.next;
                }
            }

            current = current.next;
        }
    }

    public void sort() {
        if (head == null)
            return;

        for (Node i = head; i != null; i = i.next) {
            for (Node j = i.next; j != null; j = j.next) {
                if (i.data > j.data) {
                    int t = i.data;
                    i.data = j.data;
                    j.data = t;
                }
            }
        }
    }

    public CustomLinkedList merge(CustomLinkedList other) {
        CustomLinkedList list = new CustomLinkedList();

        Node t1 = this.head;
        Node t2 = other.head;

        while (t1 != null) {
            list.addLast(t1.data);
            t1 = t1.next;
        }

        while (t2 != null) {
            list.addLast(t2.data);
            t2 = t2.next;
        }

        return list;
    }

    public CustomLinkedList cloneList() {
        CustomLinkedList copy = new CustomLinkedList();

        Node temp = head;

        while (temp != null) {
            copy.addLast(temp.data);
            temp = temp.next;
        }

        return copy;
    }

