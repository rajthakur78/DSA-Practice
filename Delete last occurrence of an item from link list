// ---------->>>> Delete last occurrence of an item from link list <<<<----------
class linkList {

    private Node head;
    private Node tail;
    private int size;

    public linkList() {
        this.head = null;
        this.tail = null;
        this.size = 0;
    }

    void insertFirst(int value) {
        Node newNode = new Node(value);
        newNode.next = head;
        head = newNode;

        if (tail == null) {
            tail = head;
        }
        size++;
    }

    void InsertLast(int value) {
        if (head == null) {
            insertFirst(value);
            return;
        }

        Node newNode = new Node(value);
        tail.next = newNode;
        tail = newNode;
        size++;
    }

    void InsertIndex(int index, int value) {
        if (index == 0) {
            insertFirst(value);
            return;
        }

        if (index == size) {
            InsertLast(value);
            return;
        }

        Node temp = head;
        for (int i = 0; i < index - 1; i++) {
            temp = temp.next;
        }

        Node newnNode = new Node(value);
        newnNode.next = temp.next;
        temp.next = newnNode;
        size++;
    }

    void Lastoccur(int value) {
        Node prev = null;
        Node current = head;
        while (current != null) {
            Node next = current.next;
            current.next = prev;
            prev = current;
            current = next;
        }
        head = prev;

        Node temp = head;
        int idx = 0;
        Node delete = head;
        while (temp.value != value) {
            temp = temp.next;
            idx++;
        }
        for (int i = 0; i < idx - 1; i++) {
            delete = delete.next;
        }

        delete.next = delete.next.next;
        size--;
    }

    void display() {
        Node temp = head;
        while (temp != null) {
            System.out.print(temp.value + " -> ");
            temp = temp.next;
        }
        System.out.println("END");
    }

    class Node {

        private int value;
        private Node next;

        public Node(int value) {
            this.value = value;
        }

        public Node(int value, Node next) {
            this.value = value;
            this.next = next;
        }
    }
}

public class dltLastOccur {

    public static void main(String[] args) {
        linkList LL = new linkList();
        LL.insertFirst(12);
        LL.insertFirst(21);
        LL.InsertLast(45);
        LL.InsertLast(55);
        LL.InsertIndex(2, 54);
        LL.InsertIndex(3, 98);
        LL.display();

        System.out.println("Reverse LinkedList");
        LL.Lastoccur(21);
        LL.display();
    }
}
